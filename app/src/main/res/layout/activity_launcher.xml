<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <!-- Home Screen -->
    <LinearLayout
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="80dp"
        android:paddingHorizontal="32dp">

        <!-- Clock -->
        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FFFFFFFF"
            android:textSize="96sp"
            android:fontFamily="sans-serif-thin"
            android:layout_marginBottom="8dp" />

        <!-- Date -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#66FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="48dp" />

        <!-- Focus Indicator -->
        <TextView
            android:id="@+id/focusIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="focus"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:visibility="gone"
            android:layout_marginBottom="4dp" />

        <!-- Focus Timer -->
        <TextView
            android:id="@+id/focusTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25:00"
            android:textColor="#B3FFFFFF"
            android:textSize="32sp"
            android:fontFamily="sans-serif-thin"
            android:visibility="gone"
            android:layout_marginBottom="48dp" />

        <!-- Music Player -->
        <LinearLayout
            android:id="@+id/musicPlayer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="48dp">

            <TextView
                android:id="@+id/tvTrackTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#B3FFFFFF"
                android:textSize="14sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvTrackArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#66FFFFFF"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="8dp" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#8AB4F8"
                android:thumbTint="#8AB4F8"
                android:progressBackgroundTint="#33FFFFFF"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:id="@+id/btnPrev"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_skip_previous"
                    android:tint="#66FFFFFF"
                    android:padding="4dp"
                    android:layout_marginEnd="24dp" />

                <ImageView
                    android:id="@+id/btnPlayPause"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_play"
                    android:tint="#FFFFFFFF"
                    android:padding="4dp"
                    android:layout_marginHorizontal="24dp" />

                <ImageView
                    android:id="@+id/btnNext"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_skip_next"
                    android:tint="#66FFFFFF"
                    android:padding="4dp"
                    android:layout_marginStart="24dp" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Pinned Apps -->
        <LinearLayout
            android:id="@+id/pinnedApps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Bottom Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/btnAllApps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/all_apps"
                android:textColor="#66FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />

            <TextView
                android:id="@+id/btnFocus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/focus"
                android:textColor="#66FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />

            <TextView
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:textColor="#66FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- All Apps Overlay -->
    <FrameLayout
        android:id="@+id/allAppsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnCloseAllApps"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:tint="#66FFFFFF"
                android:layout_gravity="end"
                android:padding="8dp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_search"
                android:hint="@string/search_hint"
                android:textColorHint="#66FFFFFF"
                android:textColor="#FFFFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/appsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </FrameLayout>

    <!-- Focus Mode Overlay -->
    <FrameLayout
        android:id="@+id/focusOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/btnCloseFocus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:tint="#66FFFFFF"
                android:layout_gravity="end"
                android:padding="8dp"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/focus_mode"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.3"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvFocusCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25:00"
                android:textColor="#FFFFFFFF"
                android:textSize="72sp"
                android:fontFamily="sans-serif-thin"
                android:layout_marginBottom="48dp" />

            <!-- Tab Selector -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/btnPomodoro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pomodoro"
                    android:textColor="#FFFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_outline" />

                <TextView
                    android:id="@+id/btnShortBreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/short_break"
                    android:textColor="#66FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/btnLongBreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/long_break"
                    android:textColor="#66FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp" />

            </LinearLayout>

            <!-- Controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnStartFocus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/start"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="32dp"
                    android:paddingVertical="12dp"
                    android:background="@drawable/bg_outline"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/btnResetFocus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reset"
                    android:textColor="#66FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="32dp"
                    android:paddingVertical="12dp" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
