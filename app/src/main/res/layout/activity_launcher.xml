<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- ViewFlipper: page 0 = clock, page 1 = player -->
        <ViewFlipper
            android:id="@+id/clockFlipper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inAnimation="@anim/slide_in_right"
            android:outAnimation="@anim/slide_out_left"
            android:layout_marginBottom="12dp">

            <!-- Page 0: Clock -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvClock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#FFFFFFFF"
                    android:textSize="72sp"
                    android:fontFamily="sans-serif-thin"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#66FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-light" />

            </LinearLayout>

            <!-- Page 1: Music Player -->
            <LinearLayout
                android:id="@+id/musicPlayer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp"
                android:paddingStart="4dp"
                android:paddingEnd="8dp"
                android:background="#1AFFFFFF">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTrackTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#B3FFFFFF"
                        android:textSize="13sp"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvTrackArtist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#66FFFFFF"
                        android:textSize="11sp"
                        android:singleLine="true"
                        android:ellipsize="end" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/btnPrev"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_skip_previous"
                    android:tint="#66FFFFFF"
                    android:padding="2dp"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:id="@+id/btnPlayPause"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_play"
                    android:tint="#FFFFFFFF"
                    android:padding="2dp"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:id="@+id/btnNext"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_skip_next"
                    android:tint="#66FFFFFF"
                    android:padding="2dp" />

            </LinearLayout>

        </ViewFlipper>

        <!-- App List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/appsList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

    </LinearLayout>

    <!-- Focus Mode Overlay -->
    <FrameLayout
        android:id="@+id/focusOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/btnCloseFocus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:tint="#66FFFFFF"
                android:layout_gravity="end"
                android:padding="8dp"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/focus_mode"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.3"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvFocusCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25:00"
                android:textColor="#FFFFFFFF"
                android:textSize="79sp"
                android:fontFamily="sans-serif-thin"
                android:layout_marginBottom="48dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/btnPomodoro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pomodoro"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_outline" />

                <TextView
                    android:id="@+id/btnShortBreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/short_break"
                    android:textColor="#66FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/btnLongBreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/long_break"
                    android:textColor="#66FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnStartFocus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/start"
                    android:textColor="#FFFFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="32dp"
                    android:paddingVertical="12dp"
                    android:background="@drawable/bg_outline"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/btnResetFocus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reset"
                    android:textColor="#66FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="32dp"
                    android:paddingVertical="12dp" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
